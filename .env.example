# ════════════════════════════════════════════════════════════════════════
# ProjectOS · Variables de entorno — Stack de despliegue: Netlify + Supabase
# Copia a .env.local (frontend) y configura las mismas en el panel de Netlify.
# ════════════════════════════════════════════════════════════════════════

# ── Supabase (Project Settings → API) ───────────────────────────────────
# Públicas (van al navegador, seguras de exponer):
NEXT_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi...anon"

# SECRETA — solo backend (seed, Edge Functions). NUNCA en el navegador ni en git:
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi...service_role"

# ── Administrador de cuentas (para seed-admin.mjs) ──────────────────────
ADMIN_EMAIL="admin@projectos.app"
ADMIN_PASSWORD="Admin#ProjectOS2026"
ADMIN_NAME="Administrador de Cuentas"

# ── IA (opcional; usado por la Edge Function ai-assistant) ──────────────
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ────────────────────────────────────────────────────────────────────────
# Dónde se definen:
#   NEXT_PUBLIC_*          → Netlify (Environment variables) y .env.local local
#   SUPABASE_SERVICE_ROLE_KEY, OPENAI_* → Supabase (Edge Functions secrets) y
#                            tu shell local al correr el seed. NO en Netlify.
# ════════════════════════════════════════════════════════════════════════
