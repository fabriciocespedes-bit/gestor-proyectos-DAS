{
  "name": "projectos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @projectos/db generate",
    "db:migrate": "pnpm --filter @projectos/db migrate",
    "db:rls": "pnpm --filter @projectos/db rls:apply",
    "db:seed": "pnpm --filter @projectos/db seed",
    "db:test-rls": "pnpm --filter @projectos/db test:rls",
    "db:test-supabase": "node supabase/rls.test.mjs",
    "api:dev": "pnpm --filter @projectos/api dev"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
